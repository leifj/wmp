[
  {
    "id": "message-deliver-plaintext",
    "description": "Deliver a plaintext JSON message in a TLS session.",
    "conformance_level": "basic",
    "input": {
      "jsonrpc": "2.0",
      "method": "wmp.message.deliver",
      "params": {
        "wmp": {
          "version": "0.1",
          "session_id": "ses-a1b2c3d4",
          "sender": "did:web:alice.example.com",
          "timestamp": "2026-04-29T10:15:30Z"
        },
        "to": ["did:web:bob.example.com"],
        "content_type": "application/json",
        "body": {
          "text": "Hello, Bob!"
        }
      }
    },
    "notes": "Notification — no response expected. Recipient validates session_id and sender membership."
  },
  {
    "id": "message-deliver-encrypted",
    "description": "Deliver an MLS-encrypted message.",
    "conformance_level": "secure",
    "input": {
      "jsonrpc": "2.0",
      "method": "wmp.message.deliver",
      "params": {
        "wmp": {
          "version": "0.1",
          "session_id": "ses-a1b2c3d4",
          "sender": "did:web:alice.example.com",
          "encrypted": true,
          "epoch": 3
        },
        "ciphertext": "dGVzdC1jaXBoZXJ0ZXh0LWV4YW1wbGU"
      }
    },
    "notes": "ciphertext is base64url-encoded MLS MLSMessage. Recipient decrypts using epoch 3 keys."
  },
  {
    "id": "message-ack-received",
    "description": "Acknowledge receipt of a message.",
    "conformance_level": "basic",
    "input": {
      "jsonrpc": "2.0",
      "method": "wmp.message.ack",
      "params": {
        "wmp": {
          "version": "0.1",
          "session_id": "ses-a1b2c3d4",
          "sender": "did:web:bob.example.com"
        },
        "message_ids": ["msg-001"],
        "status": "received"
      }
    },
    "notes": "Notification — no response expected."
  },
  {
    "id": "message-deliver-with-signature",
    "description": "Deliver a message with a non-repudiation signature.",
    "conformance_level": "registered",
    "input": {
      "jsonrpc": "2.0",
      "method": "wmp.message.deliver",
      "params": {
        "wmp": {
          "version": "0.1",
          "session_id": "ses-a1b2c3d4",
          "sender": "did:web:alice.example.com",
          "timestamp": "2026-04-29T10:15:30Z",
          "signature": {
            "alg": "ES256",
            "kid": "did:web:alice.example.com#key-1",
            "value": "MEUCIQC7k..."
          }
        },
        "to": ["did:web:bob.example.com"],
        "content_type": "application/json",
        "body": { "text": "Signed message" }
      }
    },
    "notes": "Signature computed over JCS-canonicalized params (excluding wmp metadata). Verifiable by third parties."
  }
]
